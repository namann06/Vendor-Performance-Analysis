# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# IPYNB checkpoints
.ipynb_checkpoints/

# Database files (local SQLite database should not be pushed)
*.db
*.sqlite

# Logs
logs/*.log
*.log

# Root-level raw CSV datasets (preventing large local datasets from being tracked)
/*.csv

# IDE / Editor configuration
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# OS metadata
.DS_Store
Thumbs.db
